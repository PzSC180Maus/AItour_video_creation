.home-back-btn {
  position: absolute;
  left: 0;
  top: 50%;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 248, 234, 0.96);
  box-shadow: 0 10rpx 26rpx rgba(72, 59, 37, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transform: translateY(-50%);
  padding: 0;
  box-sizing: border-box;
  z-index: 3;
}

.home-back-btn::after {
  border: 0;
}

.home-back-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
  flex-shrink: 0;
}