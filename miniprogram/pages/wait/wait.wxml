<view class="page">
  <view class="page-bg"></view>
  <view class="container">
    <view class="content">
      <view class="card">
        <view class="preview-wrap">
          <block wx:if="{{coverUrl}}">
            <image
              class="preview"
              src="{{coverUrl}}"
              mode="aspectFill"
            />
          </block>
          <block wx:else>
            <view class="preview"></view>
          </block>
          <view class="play-badge">▶</view>
        </view>

        <view class="title">回忆浮现中…</view>
        <view class="subtitle">正在生成你的视频，请稍候</view>

        <view class="progress">
          <view class="bar">
            <view class="bar-inner" style="width: {{progress}}%;"></view>
          </view>
          <view class="percent">{{progress}}%</view>
        </view>
      </view>

      <view class="tip">
        <text class="tip-dot"></text>
        <text>视频生成中 请勿离开当前页面</text>
      </view>
    </view>
  </view>
</view>
