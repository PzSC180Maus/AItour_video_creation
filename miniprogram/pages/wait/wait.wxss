page {
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: linear-gradient(
  180deg,
  #70efd1 0%,
  #ddf0ba 45%,
  #ffffff 100%
  );
  }
  
  page::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
  radial-gradient(circle at top, rgba(255, 255, 255, 0.36), transparent 40%),
  linear-gradient(
  180deg,
  rgba(220, 242, 223, 0.22) 0%,
  rgba(255, 255, 255, 0) 70%
  );
  pointer-events: none;
  z-index: 0;
  }
  
  .container {
  height: 100vh;
  min-height: 100vh;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 32rpx 32rpx;
  box-sizing: border-box;
  overflow: hidden;
  }
  

/* 居中的内容容器，控制最大宽度 */
.content {
  width: 100%;
  max-width: 700rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

/* 卡片样式 */
.card {
  width: 100%;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 28rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 36rpx rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(10px);
}

.preview-wrap {
  position: relative;
  border-radius: 22rpx;
  overflow: hidden;
  height: 360rpx;
  background: #eef2f7;
}

.preview {
  width: 100%;
  height: 100%;
}

.play-badge {
  position: absolute;
  left: 22rpx;
  bottom: 18rpx;
  width: 66rpx;
  height: 66rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #1f2329;
}

.title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  text-align: center;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(31, 35, 41, 0.6);
  text-align: center;
}

.progress {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.bar {
  flex: 1;
  height: 18rpx;
  background: rgba(31, 35, 41, 0.08);
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #2ecc71, #00c2ff);
  border-radius: 999rpx;
  transition: width 260ms ease;
}

.percent {
  width: 88rpx;
  text-align: right;
  color: rgba(31, 35, 41, 0.65);
  font-size: 24rpx;
}

/* 底部提示条 */
.tip {
  width: 100%;
  margin-top: 200rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.65);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  color: rgba(31, 35, 41, 0.65);
  font-size: 26rpx;
}

.tip-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2ecc71;
}