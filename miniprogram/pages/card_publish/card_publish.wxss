page {
  min-height: 100vh;
  background: #f6fbf9;
}

.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.panel {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(33, 54, 45, 0.08);
}

.upload,
.preview {
  width: 100%;
  height: 420rpx;
  border-radius: 14rpx;
}

.upload {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e7efea;
  overflow: hidden;
}

.placeholder {
  color: #60736b;
  font-size: 30rpx;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #f2f7f5;
  font-size: 28rpx;
  line-height: 1.5;
}

.main-btn {
  height: 82rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  background: #20392f;
  color: #ffffff;
  font-size: 30rpx;
}

.main-btn::after {
  border: 0;
}
