/* pages/scenery_select/scenery_select.wxss */
page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  background-color: rgba(207, 234, 234, 0.42);
  pointer-events: none;
  z-index: 0;
}

.container {
  min-height: 100vh;
  position: relative;
  padding: 72rpx 24rpx 176rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.page-bg {
  position: absolute;
  inset: 0;
  background-image: url("https://n.sinaimg.cn/sinakd20109/254/w960h1694/20230513/ab8e-ae218b1a6d2ba3ad9c31c89b702956ae.jpg");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  z-index: -1;
}


.rail-scroll {
  position: relative;
  z-index: 1;
  height: calc(100vh - 300rpx);
}

.rail-list {
  padding: 16rpx 0 60rpx;
  box-sizing: border-box;
}

.rail-item {
  margin-bottom: 34rpx;
  display: flex;
}

.rail-item-0 {
  justify-content: flex-start;
  padding-left: 22rpx;
}

.rail-item-1 {
  justify-content: center;
  padding-left: 62rpx;
}

.rail-item-2 {
  justify-content: flex-end;
  padding-right: 36rpx;
}

.rail-item-3 {
  justify-content: center;
  padding-left: 54rpx;
}

.rail-item-4 {
  justify-content: flex-start;
  padding-left: 6rpx;
}

.card {
width: 560rpx;
min-height: 196rpx;
padding: 18rpx 22rpx;
box-sizing: border-box;
display: flex;
align-items: center;
gap: 22rpx;
border-radius: 30rpx;
background: rgba(255, 255, 255, 0.12);
border: 2rpx solid rgba(255, 255, 255, 0.62);
box-shadow: 0 10rpx 24rpx rgba(32, 45, 40, 0.1);
transform-origin: center;
transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease, background 0.25s ease, border-color 0.25s ease;
}

.rail-item-0 .card {
  transform: rotate(-14deg) scale(0.96);
}

.rail-item-1 .card {
  transform: rotate(-8deg) scale(0.98);
}

.rail-item-2 .card {
  transform: rotate(0deg) scale(1);
}

.rail-item-3 .card {
  transform: rotate(-7deg) scale(0.98);
}

.rail-item-4 .card {
  transform: rotate(-28deg) scale(0.95);
}

.card.active {
background: rgba(255, 255, 255, 0.18);
border-color: rgba(255, 255, 255, 0.88);
box-shadow: 0 14rpx 30rpx rgba(32, 45, 40, 0.14);
opacity: 1;
}

.card-media {
  position: relative;
  width: 172rpx;
  height: 172rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.14);
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
}

.play-icon {
  position: absolute;
  inset: 0;
}

.play-icon::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  margin-left: -20rpx;
  margin-top: -24rpx;
  width: 0;
  height: 0;
  border-top: 24rpx solid transparent;
  border-bottom: 24rpx solid transparent;
  border-left: 38rpx solid rgba(255, 255, 255, 0.92);
  filter: drop-shadow(0 2rpx 6rpx rgba(0, 0, 0, 0.12));
}

.card-content {
  flex: 1;
  display: flex;
  align-items: center;
}

.card-desc {
  font-size: 34rpx;
  line-height: 1.45;
  color: #4d4b39;
  font-family: "STKaiti", "KaiTi", "Kaiti SC", serif;
  letter-spacing: 2rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 42rpx;
  z-index: 2;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.confirm-btn {
  width: 248rpx;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(37, 48, 47, 0.58);
  border: 2rpx solid rgba(223, 236, 232, 0.26);
  color: rgba(255, 255, 255, 0.92);
  font-size: 30rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 10rpx 24rpx rgba(12, 20, 20, 0.2);
  pointer-events: auto;
  font-family: "STKaiti", "KaiTi", "Kaiti SC", serif;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn:active {
  background: rgba(24, 33, 32, 0.72);
}