
.page {
  min-height: 100vh;
  padding: 40rpx 28rpx 190rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff8ec 0 138rpx, #d2f0eb 138rpx 100%);
}

.template-scroll {
  height: calc(100vh - 230rpx - env(safe-area-inset-top));
  margin-top: 0;
  padding: 112rpx 8rpx 82rpx;
  box-sizing: border-box;
  background: #d2f0eb;  /* 添加背景色，与 page 渐变底部颜色一致 */
}

.template-scroll {
  background: transparent;
}
home-back-button {
  position: fixed;
  top: 50rpx;
  left: 20rpx;
  z-index: 100;
}
.top-dock {
  position: fixed;
  top: calc(46rpx + env(safe-area-inset-top));
  left: 88rpx;
  z-index: 20;
  width: 300rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 22rpx;
  border-radius: 44rpx;
  background: rgba(255, 253, 247, 0.98);
  box-shadow:
    0 12rpx 22rpx rgba(34, 41, 43, 0.18),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
}

.headline-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin: 0 0 42rpx;
}

.landscape-pill {
  flex-shrink: 0;
  min-width: 238rpx;
  max-width: 292rpx;
  height: 54rpx;
  padding: 0 22rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  background: #62c9c4;
  box-shadow:
    0 7rpx 12rpx rgba(35, 104, 105, 0.24),
    inset 0 -3rpx 0 rgba(32, 156, 166, 0.35);
  box-sizing: border-box;
}

.headline-pill,
.recommend-pill {
  min-width: 150rpx;
  height: 56rpx;
  padding: 0 26rpx;
  border-radius: 0 0 30rpx 30rpx;
  color: #ffffff;
  font-size: 29rpx;
  line-height: 56rpx;
  text-align: center;
  background: rgba(113, 211, 209, 0.78);
  box-shadow: 0 3rpx 0 #2bbfd3;
  box-sizing: border-box;
}

.headline-pill {
  margin-left: 20rpx;
  color: rgba(77, 95, 96, 0.62);
  background: transparent;
  box-shadow: 0 3rpx 0 #2bbfd3;
}

.trend {
  flex: 1;
  min-width: 0;
  padding-bottom: 4rpx;
  border-bottom: 5rpx solid rgba(99, 174, 176, 0.45);
  color: rgba(86, 91, 92, 0.48);
  font-size: 28rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.trend-fire {
  margin-right: 12rpx;
  color: #e84a2f;
}

.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 62rpx;
  padding: 0 30rpx;
}

.feature-card,
.template-card {
  position: relative;
  overflow: hidden;
  border: 7rpx solid #ffffff;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 9rpx 15rpx rgba(38, 54, 54, 0.28);
  box-sizing: border-box;
}

.feature-card.active,
.template-card.active {
  border-color: #68c9c4;
}

.feature-image {
  display: block;
  width: 100%;
  height: 318rpx;
  border-radius: 23rpx 23rpx 18rpx 18rpx;
}

.tag {
  min-height: 65rpx;
  padding: 12rpx 14rpx 10rpx;
  color: #070b0c;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
  background: #ffffff;
  box-sizing: border-box;
}

.recommend-panel {
  margin-top: 28rpx;
  padding: 0 24rpx 0;
  border-radius: 34rpx;
  background: rgba(177, 233, 226, 0.9);
  box-shadow: 0 10rpx 16rpx rgba(57, 100, 99, 0.24);
  box-sizing: border-box;
}

.recommend-head {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.recommend-pill {
  margin-left: 0;
  color: #ffffff;
  background: transparent;
  box-shadow: 0 3rpx 0 #ffffff;
}

.search-bar {
  position: relative;
  flex: 1;
  height: 52rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 6rpx 9rpx rgba(29, 58, 60, 0.18);
}

.panel-search-symbol {
  position: absolute;
  left: 19rpx;
  top: 12rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #6d7c7d;
  border-radius: 50%;
  box-sizing: border-box;
}

.panel-search-symbol::after {
  content: "";
  position: absolute;
  right: -10rpx;
  bottom: -7rpx;
  width: 13rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #6d7c7d;
  transform: rotate(45deg);
}

.recommend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx 28rpx;
}

.template-image {
  display: block;
  width: 100%;
  height: 146rpx;
  border-radius: 22rpx;
}

.confirm-btn {
  position: fixed;
  left: 50%;
  bottom: calc(124rpx + env(safe-area-inset-bottom));
  z-index: 31;
  width: 316rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border-radius: 0 0 30rpx 30rpx;
  color: rgba(75, 86, 88, 0.62);
  font-size: 26rpx;
  line-height: 56rpx;
  text-align: center;
  background: #ffffff;
  box-shadow: 0 3rpx 0 #2bbfd3;
  transform: translateX(-50%);
}

.confirm-btn::after {
  border: 0;
}

.bottom-dock {
  position: fixed;
  left: 64rpx;
  right: 64rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 30;
  height: 88rpx;
  padding: 0 52rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 8rpx 18rpx rgba(37, 65, 66, 0.16);
  box-sizing: border-box;
}

.nav-icon {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #18252d;
  box-sizing: border-box;
}

.bottom-dock .nav-icon {
  width: 62rpx;
  height: 62rpx;
  background: #69ccc5;
  box-shadow: 0 7rpx 13rpx rgba(20, 79, 82, 0.22);
}

.top-icon-img {
  display: block;
  width: 34rpx;
  height: 34rpx;
}

.video-img {
  width: 40rpx;
  height: 40rpx;
  transform: translateX(0);
}

.camera-img {
  width: 35rpx;
  height: 35rpx;
  transform: translateY(0rpx);
}

.search-img {
  width: 65rpx;
  height: 65rpx;
  transform: translate(0, 0);
}

.bottom-dock .dock-icon-img,
.top-dock .dock-icon-img {
  display: block;
  width: 48rpx;
  height: 48rpx;
}

.bottom-dock .stack-img,
.top-dock .stack-img {
  width: 45rpx;
  height: 45rpx;
}

.bottom-dock .compose-img,
.top-dock .compose-img {
  width: 45rpx;
  height: 45rpx;
  transform: translate(2rpx, -3rpx);
}

.bottom-dock .user-img,
.top-dock .user-img {
  width: 45rpx;
  height: 45rpx;
  transform: translate(-1rpx, -3rpx);
}
