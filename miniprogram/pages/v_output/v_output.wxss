page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: "STKaiti", "KaiTi", serif;
  background: #dfe7dc;
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  background-color: rgba(207, 234, 234, 0.18);
  pointer-events: none;
  z-index: 0;
}

.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.page-bg {
  position: fixed;
  inset: 0;
  background-image: url("https://n.sinaimg.cn/sinakd20109/254/w960h1694/20230513/ab8e-ae218b1a6d2ba3ad9c31c89b702956ae.jpg");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  transform: scale(1.03);
  z-index: 0;
}

.page-bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(236, 243, 239, 0.32) 100%),
    rgba(220, 234, 229, 0.26);
}

.container {
  min-height: 100vh;
  position: relative;
  z-index: 1;
  padding: 72rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.content {
  width: 100%;
  max-width: 700rpx;
  margin: 0 auto;
}

.card {
  width: 100%;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  box-shadow:
    0 12rpx 28rpx rgba(33, 48, 36, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(12px);
}

.video-wrap {
  border-radius: 22rpx;
  overflow: hidden;
  height: 360rpx;
  background: rgba(238, 242, 247, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
}

.video {
  width: 100%;
  height: 100%;
}

.headline {
  margin-top: 22rpx;
  font-size: 38rpx;
  font-weight: 800;
  text-align: center;
  color: #2f3d33;
}

.desc {
  margin-top: 10rpx;
  text-align: center;
  color: rgba(31, 35, 41, 0.62);
  font-size: 26rpx;
}

.copy-card {
  margin-top: 24rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.26);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

.copy-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #405142;
  margin-bottom: 14rpx;
}

.copy-scroll {
  max-height: 260rpx;
}

.copy-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: #425145;
  word-break: break-all;
}

.actions {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  height: 90rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(255, 255, 255, 0.40);
  color: rgba(31, 35, 41, 0.84);
  font-size: 32rpx;
  font-weight: 700;
  box-shadow:
    0 8rpx 16rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px);
  transition:
    transform 0.2s ease,
    background 0.2s ease,
    box-shadow 0.2s ease,
    opacity 0.2s ease;
}

.btn:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.56);
  box-shadow:
    0 6rpx 12rpx rgba(0, 0, 0, 0.05),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
}

.btn::after {
  border: none;
}

.btn.outline {
  background: rgba(255, 255, 255, 0.28);
}

.btn.outline:active {
  background: rgba(255, 255, 255, 0.40);
}