.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20px;
}

.hero {
  background: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.video {
  width: 100%;
  height: 200px;
  border-radius: 12px;
  object-fit: cover;
}

.image {
  width: 100%;
  height: 200px;
  border-radius: 12px;
  object-fit: cover;
  display: block;
}

.title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-top: 12px;
  line-height: 1.4;
}

.author-line {
  display: flex;
  align-items: center;
  margin-top: 10px;
}

.author-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  margin-right: 8px;
}

.author {
  font-size: 14px;
  color: #666;
}

.copy {
  font-size: 14px;
  color: #555;
  margin-top: 10px;
  line-height: 1.6;
}

.main-btn {
  width: 100%;
  height: 40px;
  background: #07c160;
  color: #fff;
  font-size: 15px;
  border-radius: 20px;
  margin-top: 14px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main-btn::after {
  border: none;
}

.target {
  background: #fff;
  display: flex;
  justify-content: space-around;
  padding: 14px 16px;
  margin-bottom: 12px;
}

.stat {
  font-size: 14px;
  color: #666;
}

.favorite {
  width: 100%;
  height: 40px;
  background: linear-gradient(135deg, #1f9a9c 0%, #9c822b 100%);
  color: #fff;
  font-size: 15px;
  border: none;
  border-radius: 20px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite::after {
  border: none;
}

.comments {
  background: #fff;
  padding: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.comment {
  display: flex;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.comment:last-child {
  border-bottom: none;
}

.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  margin-right: 10px;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-name {
  font-size: 13px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.comment-content {
  font-size: 14px;
  color: #555;
  line-height: 1.5;
}

.empty {
  text-align: center;
  padding: 20px 0;
  font-size: 14px;
  color: #999;
}

/* 底部评论输入框 */
.comment-editor-bottom {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  background: #f8f8f8;
  border-radius: 20px;
  margin-top: 12px;
}

.comment-input {
  flex: 1;
  font-size: 14px;
  border: none;
  outline: none;
  background: transparent;
  min-height: 24px;
  max-height: 60px;
  padding: 4px 0;
  resize: none;
}

.send-btn {
  width: 24px;
  height: 24px;
  margin-left: 8px;
  flex-shrink: 0;
}