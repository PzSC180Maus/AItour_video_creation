<view class="page">
  <view class="hero" wx:if="{{type === 'post'}}">
    <video class="video" src="{{item.video_url}}" poster="{{item.cover_url}}" controls></video>
    <view class="title">{{item.title || '旅行作品'}}</view>
    <view class="author-line">
      <image class="author-avatar" wx:if="{{item.author_avatar}}" src="{{item.author_avatar}}" mode="aspectFill"></image>
      <text class="author">{{item.author_name || '用户'}}</text>
    </view>
    <view class="copy">{{item.share_text || '暂无文案'}}</view>
    <button class="main-btn" bindtap="usePostCard">使用绑定卡片</button>
  </view>

  <view class="hero" wx:else>
    <image class="image" src="{{item.image_url}}" mode="aspectFill"></image>
    <view class="title">{{item.author_name || '用户'}}的卡片</view>
    <view class="copy">{{item.emotion_text || '暂无情绪描述'}}</view>
    <button class="main-btn" bindtap="useCard">立即使用</button>
  </view>

  <view class="target">
    <view class="stat">点赞 {{target.likes || 0}}</view>
    <view class="stat">收藏 {{target.favorites || 0}}</view>
    <view class="stat">评论 {{target.comments || 0}}</view>
  </view>

  <button class="favorite" bindtap="favoriteCurrent">收藏当前内容</button>

  <view class="comments">
    <view class="section-title">评论</view>
    <block wx:for="{{target.List}}" wx:key="comment_id">
      <view class="comment">
        <image class="avatar" wx:if="{{item.author_avatar}}" src="{{item.author_avatar}}" mode="aspectFill"></image>
        <view class="comment-body">
          <view class="comment-name">{{item.author_name || '用户'}}</view>
          <view class="comment-content">{{item.content}}</view>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{commentLoading}}">评论加载中...</view>
    <view class="empty" wx:if="{{!commentLoading && (!target.List || target.List.length === 0)}}">暂无评论</view>
    
    <!-- 底部评论输入框 -->
    <view class="comment-editor-bottom">
      <textarea class="comment-input" value="{{commentInput}}" bindinput="onCommentInput" placeholder="写下你的评论" maxlength="300"></textarea>
      <image class="send-btn" src="/images/icons/send.svg" bindtap="submitComment" mode="aspectFill"></image>
    </view>
  </view>
</view>
