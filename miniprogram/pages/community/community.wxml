<view class="page">
  <view class="top-dock">
    <view class="dock-icon {{activeTab === 'post' ? 'active' : ''}}" data-tab="post" bindtap="switchTab">
      <view class="video-symbol"></view>
    </view>
    <view class="dock-icon {{activeTab === 'card' ? 'active' : ''}}" data-tab="card" bindtap="switchTab">
      <view class="card-symbol">
        <view class="camera-bump"></view>
        <view class="camera-refresh">
          <view class="refresh-ring"></view>
          <view class="refresh-arc refresh-arc-top"></view>
          <view class="refresh-arc refresh-arc-bottom"></view>
          <view class="refresh-arrow refresh-arrow-one"></view>
          <view class="refresh-arrow refresh-arrow-two"></view>
        </view>
      </view>
    </view>
    <view class="dock-icon" bindtap="refreshCurrent">
      <view class="search-symbol"></view>
    </view>
  </view>

  <scroll-view class="masonry" scroll-y bindscrolltolower="loadMore">
    <view class="feed-panel">
      <view class="columns">
        <view class="column">
          <block wx:for="{{leftList}}" wx:key="target_id">
            <view class="content-card {{index % 3 === 1 ? 'short' : ''}}" bindtap="openDetail" data-type="{{activeTab}}" data-index="{{item.__index}}">
              <image class="cover" src="{{activeTab === 'post' ? item.cover_url : item.image_url}}" mode="aspectFill"></image>
              <view wx:if="{{activeTab === 'post'}}" class="play-dot"></view>
              <view class="caption">
                <image class="avatar" src="{{item.author_avatar}}" mode="aspectFill"></image>
                <view class="caption-text">
                  <view class="title">{{activeTab === 'post' ? (item.title || '旅行作品') : (item.emotion_text || '我的旅行卡片')}}</view>
                  <view class="name">{{item.author_name || '用户'}}</view>
                </view>
              </view>
            </view>
          </block>
        </view>

        <view class="column offset">
          <block wx:for="{{rightList}}" wx:key="target_id">
            <view class="content-card {{index % 3 === 0 ? 'short' : ''}}" bindtap="openDetail" data-type="{{activeTab}}" data-index="{{item.__index}}">
              <image class="cover" src="{{activeTab === 'post' ? item.cover_url : item.image_url}}" mode="aspectFill"></image>
              <view wx:if="{{activeTab === 'post'}}" class="play-dot"></view>
              <view class="caption">
                <image class="avatar" src="{{item.author_avatar}}" mode="aspectFill"></image>
                <view class="caption-text">
                  <view class="title">{{activeTab === 'post' ? (item.title || '旅行作品') : (item.emotion_text || '我的旅行卡片')}}</view>
                  <view class="name">{{item.author_name || '用户'}}</view>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{!loading && currentListLength === 0}}">暂无内容</view>
    <view class="loading" wx:if="{{loading}}">加载中...</view>
    <view class="loading bottom-space" wx:if="{{!hasMore && currentListLength > 0}}">没有更多了</view>
  </scroll-view>

  <view class="bottom-dock">
    <view class="nav-icon {{activeTab === 'post' ? 'active' : ''}}" data-tab="post" bindtap="switchTab">
      <view class="stack-symbol">
        <view class="stack-layer stack-layer-top"></view>
        <view class="stack-layer stack-layer-mid"></view>
        <view class="stack-layer stack-layer-bottom"></view>
      </view>
    </view>
    <view class="nav-icon compose" bindtap="goPublishCurrent">
      <view class="compose-symbol">
        <view class="compose-base"></view>
        <view class="compose-pen-cutout"></view>
        <view class="compose-pen"></view>
      </view>
    </view>
    <view class="nav-icon" bindtap="goProfile">
      <view class="user-symbol"></view>
    </view>
  </view>
</view>
