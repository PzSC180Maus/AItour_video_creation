.refresh-ring {
  display: none !important;
}

.refresh-arc {
  position: absolute ;
  left: 3rpx ;
  width: 13rpx ;
  height: 7rpx ;
  border: 3rpx solid #18252d ;
  box-sizing: border-box ;
  background: transparent ;
}

.refresh-arc-top {
  top: 2rpx ;
  border-bottom: 0 ;
  border-radius: 13rpx 13rpx 0 0 ;
}

.refresh-arc-bottom {
  bottom: 2rpx ;
  border-top: 0 ;
  border-radius: 0 0 13rpx 13rpx ;
}

.refresh-arrow {
  position: absolute !important;
  width: 6rpx !important;
  height: 6rpx !important;
  background: #18252d !important;
  clip-path: polygon(0 0, 100% 50%, 0 100%) !important;
}

.refresh-arrow-one {
  right: 0 !important;
  top: 5rpx !important;
  transform: rotate(90deg) !important;
}

.refresh-arrow-two {
  left: 0 !important;
  bottom: 5rpx !important;
  transform: rotate(270deg) !important;
}

page {
  min-height: 100vh;
  background: #fff8ec;
  color: #15252a;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 166rpx 28rpx 132rpx;
  box-sizing: border-box;
  overflow: hidden;
  background:
    linear-gradient(180deg, #fff8ec 0 138rpx, #d2f0eb 138rpx 100%),
    #fff8ec;
}

.top-dock {
  position: fixed;
  top: calc(46rpx + env(safe-area-inset-top));
  left: 88rpx;
  z-index: 20;
  width: 300rpx;
  height: 80rpx;
  padding: 0 22rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 253, 247, 0.98);
  box-shadow:
    0 12rpx 22rpx rgba(34, 41, 43, 0.18),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
}

.dock-icon,
.nav-icon {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #18252d;
  box-sizing: border-box;
}

.dock-icon.active {
  background: #50656a;
  box-shadow: 0 0 0 5rpx #6cccca inset;
}

.video-symbol,
.card-symbol,
.search-symbol,
.stack-symbol,
.compose-symbol,
.user-symbol {
  position: relative;
}

.video-symbol {
  width: 22rpx;
  height: 20rpx;
  left: -4rpx;
  border-radius: 5rpx;
  background: #ffffff;
}

.video-symbol::after {
  content: "";
  position: absolute;
  right: -10rpx;
  top: 2rpx;
  width: 8rpx;
  height: 16rpx;
  background: #ffffff;
  clip-path: polygon(0 28%, 100% 0, 100% 100%, 0 72%);
}

.card-symbol {
  width: 32rpx;
  height: 22rpx;
  border-radius: 6rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.card-symbol::before {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 6rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #18252d;
  box-shadow: inset 0 0 0 3rpx #ffffff;
}

.card-symbol::after {
  content: "";
  position: absolute;
  left: 10rpx;
  top: -3rpx;
  width: 12rpx;
  height: 3rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #ffffff;
}

.search-symbol {
  width: 27rpx;
  height: 27rpx;
  border-radius: 50%;
  border: 4rpx solid #ffffff;
  box-sizing: border-box;
}

.search-symbol::after {
  content: "";
  position: absolute;
  right: -10rpx;
  bottom: -5rpx;
  width: 17rpx;
  height: 5rpx;
  border-radius: 8rpx;
  background: #ffffff;
  transform: rotate(45deg);
}

.masonry {
  position: relative;
  z-index: 1;
  height: calc(100vh - 298rpx - env(safe-area-inset-top));
}

.feed-panel {
  min-height: calc(100vh - 336rpx);
  padding: 16rpx 14rpx 18rpx;
  border-radius: 34rpx;
  background: #bfe8e3;
  box-shadow:
    0 14rpx 24rpx rgba(43, 91, 92, 0.18),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.32);
  box-sizing: border-box;
}

.columns {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.column {
  flex: 1;
  min-width: 0;
}

.column.offset {
  padding-top: 18rpx;
}

.content-card {
  position: relative;
  overflow: hidden;
  margin-bottom: 18rpx;
  border: 7rpx solid #ffffff;
  border-radius: 27rpx;
  background: #ffffff;
  box-shadow: 0 7rpx 14rpx rgba(34, 58, 59, 0.23);
  box-sizing: border-box;
}

.cover {
  display: block;
  width: 100%;
  height: 266rpx;
  border-radius: 18rpx;
  background: #d3eee9;
}

.content-card.short .cover {
  height: 214rpx;
}

.play-dot {
  position: absolute;
  top: 18rpx;
  right: 14rpx;
  width: 0;
  height: 0;
  border-top: 17rpx solid transparent;
  border-bottom: 17rpx solid transparent;
  border-left: 22rpx solid rgba(255, 255, 255, 0.96);
  filter: drop-shadow(0 2rpx 5rpx rgba(0, 0, 0, 0.22));
}

.caption {
  position: relative;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 75rpx;
  padding: 9rpx 8rpx 8rpx 2rpx;
  box-sizing: border-box;
}

.avatar {
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  margin-left: -2rpx;
  border-radius: 50%;
  background: #d4ebe7;
  box-shadow:
    0 0 0 5rpx #ffffff,
    0 4rpx 10rpx rgba(28, 49, 50, 0.18);
}

.caption-text {
  min-width: 0;
  flex: 1;
}

.title {
  max-height: 58rpx;
  color: #142327;
  font-size: 24rpx;
  line-height: 1.18;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.name {
  margin-top: 2rpx;
  color: #10191d;
  font-size: 28rpx;
  line-height: 1.02;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty,
.loading {
  margin: 24rpx 16rpx 0;
  padding: 34rpx 0;
  color: #315457;
  text-align: center;
  font-size: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 247, 0.72);
}

.bottom-space {
  padding-bottom: 120rpx;
}

.bottom-dock {
  position: fixed;
  left: 54rpx;
  right: 54rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 20;
  height: 88rpx;
  padding: 0 52rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(219, 243, 238, 0.98);
  box-shadow:
    0 8rpx 20rpx rgba(28, 70, 72, 0.13),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.36);
  box-sizing: border-box;
}

.nav-icon {
  width: 62rpx;
  height: 62rpx;
  background: #8ad9d4;
  box-shadow: 0 7rpx 13rpx rgba(20, 79, 82, 0.22);
}

.nav-icon.active,
.nav-icon.compose {
  background: #69ccc5;
}

.nav-icon.active {
  border: 4rpx solid #ffffff;
}

.stack-symbol {
  width: 42rpx;
  height: 42rpx;
}

.stack-layer {
  position: absolute;
  left: 4rpx;
  width: 34rpx;
  height: 13rpx;
  background: transparent;
}

.stack-layer-top {
  top: 5rpx;
  left: 5rpx;
  width: 34rpx;
  height: 25rpx;
  background: #102127;
  clip-path: polygon(50% 0, 100% 33%, 50% 66%, 0 33%);
}

.stack-layer-mid {
  top: 23rpx;
}

.stack-layer-bottom {
  top: 27rpx;
}

.stack-layer-mid::before,
.stack-layer-mid::after,
.stack-layer-bottom::before,
.stack-layer-bottom::after {
  content: "";
  position: absolute;
  top: 2rpx;
  width: 21rpx;
  height: 4rpx;
  border-radius: 7rpx;
  background: #102127;
}

.stack-layer-mid::before,
.stack-layer-bottom::before {
  left: 0;
  transform: rotate(25deg);
  transform-origin: right center;
}

.stack-layer-mid::after,
.stack-layer-bottom::after {
  right: 0;
  transform: rotate(-25deg);
  transform-origin: left center;
}

.compose-symbol {
  width: 36rpx;
  height: 36rpx;
}

.compose-symbol::before {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: 5rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 5rpx;
  background: #102127;
}

.compose-symbol::after {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 1rpx;
  width: 10rpx;
  height: 31rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #102127;
  transform: rotate(42deg);
  transform-origin: center bottom;
  clip-path: polygon(0 0, 100% 0, 100% 76%, 50% 100%, 0 76%);
}

.user-symbol {
  width: 36rpx;
  height: 36rpx;
}

.user-symbol::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 3rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #102127;
}

.user-symbol::after {
  content: "";
  position: absolute;
  left: 5rpx;
  bottom: 3rpx;
  width: 26rpx;
  height: 17rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: #102127;
}

.compose-symbol::before,
.compose-symbol::after {
  display: none;
}

.compose-base,
.compose-pen-cutout,
.compose-pen {
  position: absolute;
}

.compose-base {
  left: 4rpx;
  bottom: 3rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 5rpx;
  background: #102127;
}

.compose-pen-cutout {
  left: 8rpx;
  top: -14rpx;
  width: 16rpx;
  height: 37rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #69ccc5;
  transform: rotate(42deg);
  transform-origin: center bottom;
  clip-path: polygon(0 0, 100% 0, 100% 76%, 50% 100%, 0 76%);
}

.compose-pen {
  left: 15rpx;
  top: -11rpx;
  width: 10rpx;
  height: 31rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #102127;
  transform: rotate(42deg);
  transform-origin: center bottom;
  clip-path: polygon(0 0, 100% 0, 100% 76%, 50% 100%, 0 76%);
}
.card-symbol {
  width: 28rpx;
  height: 22rpx;
  border: 0;
  border-radius: 6rpx;
  background: #ffffff;
}

.card-symbol::before,
.card-symbol::after {
  display: none;
}

.camera-bump {
  position: absolute;
  left: 5rpx;
  top: -4rpx;
  width: 10rpx;
  height: 6rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #ffffff;
}

.camera-refresh {
  position: absolute;
  left: 7rpx;
  top: 5rpx;
  width: 14rpx;
  height: 14rpx;
}

.refresh-ring {
  position: absolute;
  left: 1rpx;
  top: 1rpx;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #18252d;
  border-right-color: transparent;
  border-radius: 50%;
  box-sizing: border-box;
}

.refresh-ring {
  position: absolute;
  left: 0;
  top: 0;
  width: 14rpx;
  height: 14rpx;
  border: 0;
}

.refresh-ring::before,
.refresh-ring::after {
  content: "";
  position: absolute;
  left: 1rpx;
  top: 1rpx;
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #18252d;
  border-radius: 50%;
  box-sizing: border-box;
}

.refresh-ring::before {
  border-right-color: transparent;
  border-bottom-color: transparent;
  transform: rotate(20deg);
}

.refresh-ring::after {
  border-left-color: transparent;
  border-top-color: transparent;
  transform: rotate(20deg);
}

.refresh-arrow-one {
  right: -1rpx;
  top: 1rpx;
  transform: rotate(30deg);
}

.refresh-arrow-two {
  left: -1rpx;
  bottom: 1rpx;
  transform: rotate(210deg);
}
.refresh-ring::before,
.refresh-ring::after {
  border-color: transparent;
}

.refresh-ring::before {
  border-top-color: #18252d;
  border-left-color: #18252d;
  transform: rotate(28deg);
}

.refresh-ring::after {
  border-right-color: #18252d;
  border-bottom-color: #18252d;
  transform: rotate(28deg);
}
.refresh-ring::before,
.refresh-ring::after {
  left: 1rpx;
  top: 1rpx;
  width: 12rpx;
  height: 12rpx;
  border: 0;
  border-top: 3rpx solid #18252d;
  border-radius: 50%;
  box-sizing: border-box;
}

.card-symbol {
  width: 31rpx;
  height: 23rpx;
  border: 0;
  border-radius: 6rpx;
  background: #ffffff;
}

.card-symbol::before,
.card-symbol::after {
  display: none;
}

.camera-bump {
  left: 8rpx;
  top: -5rpx;
  width: 14rpx;
  height: 3rpx;
  border-radius: 5rpx 5rpx 0 0;
  background: #ffffff;
}

.camera-refresh {
  left: 7rpx;
  top: 4rpx;
  width: 19rpx;
  height: 16rpx;
}

.refresh-ring {
  left: 1rpx;
  top: 1rpx;
  width: 17rpx;
  height: 14rpx;
  border: 0;
}

.refresh-ring::before,
.refresh-ring::after {
  content: "";
  position: absolute;
  width: 14rpx;
  height: 11rpx;
  border: 0;
  border-top: 3rpx solid #18252d;
  border-radius: 50%;
  box-sizing: border-box;
}

.refresh-arrow {
  width: 5rpx;
  height: 5rpx;
  background: #18252d;
  clip-path: polygon(0 0, 100% 50%, 0 100%);
}

.refresh-arrow-one {
  right: 0;
  top: 2rpx;
  transform: rotate(0deg);
}

.refresh-arrow-two {
  left: 0;
  bottom: 1rpx;
  transform: rotate(180deg);
}
