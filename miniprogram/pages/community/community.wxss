page {
  min-height: 100vh;
  background: #f5fbf8;
  color: #22332c;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}

.profile-btn {
  margin-left: 18rpx;
  padding: 16rpx 22rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  color: #21372e;
  white-space: nowrap;
}

.tabs {
  display: flex;
  width: 100%;
  padding: 6rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.78);
}

.tab {
  flex: 1;
  padding: 16rpx 18rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #61736b;
}

.tab.active {
  color: #15392c;
  background: #baf5e6;
  font-weight: 700;
}

.ghost-btn,
.small-btn,
.publish-btn {
  margin: 0;
  border: 0;
  border-radius: 14rpx;
  background: #20392f;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
}

.ghost-btn {
  height: 58rpx;
  padding: 0 20rpx;
}

.publish-entry {
  width: 100%;
  margin-bottom: 24rpx;
}

.ghost-btn::after,
.small-btn::after,
.publish-btn::after {
  border: 0;
}

.list {
  flex: 1;
  min-height: 0;
  height: auto;
}

.item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(33, 54, 45, 0.08);
}

.thumb {
  flex: 0 0 188rpx;
  width: 188rpx;
  height: 188rpx;
  border-radius: 14rpx;
  background: #e7efea;
}

.body {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 30rpx;
  font-weight: 800;
  color: #21372e;
}

.meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7d8d86;
}

.text {
  margin-top: 12rpx;
  min-height: 64rpx;
  max-height: 96rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #3c5048;
  overflow: hidden;
}

.row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.small-btn {
  height: 54rpx;
  padding: 0 20rpx;
}

.small-btn.outline {
  background: #e8f3ef;
  color: #2b4d40;
}

.empty,
.loading {
  padding: 48rpx 0;
  text-align: center;
  color: #81918a;
  font-size: 26rpx;
}

.publish-btn {
  width: 100%;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}
