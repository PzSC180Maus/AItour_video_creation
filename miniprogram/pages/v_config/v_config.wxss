page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: "STKaiti", "KaiTi", serif;
  background: #dfe7dc;
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  background-color: rgba(207, 234, 234, 0.24);
  pointer-events: none;
  z-index: 0;
}

.page-bg {
  position: fixed;
  inset: 0;
  background-image: url("https://n.sinaimg.cn/sinakd20109/254/w960h1694/20230513/ab8e-ae218b1a6d2ba3ad9c31c89b702956ae.jpg");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  transform: scale(1.03);
  opacity: 0.78;
  z-index: 0;
}

.container {
  min-height: 100vh;
  position: relative;
  padding: 72rpx 24rpx 176rpx;
  box-sizing: border-box;
  overflow: hidden;
  z-index: 1;
}

.upload-card {
  width: 290rpx;
  height: 340rpx;
  margin: 80rpx auto 0;
  border-radius: 38rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.28);
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  box-shadow:
    0 14rpx 30rpx rgba(88, 103, 72, 0.16),
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10rpx);
}

.upload-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(237, 243, 226, 0.72) 0%, rgba(229, 236, 217, 0.54) 100%);
}

.upload-icon {
  font-size: 42rpx;
  margin-bottom: 18rpx;
  color: #4f6251;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #4e5f4b;
  font-weight: 700;
  letter-spacing: 3rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.group-title {
  margin-top: 40rpx;
  width: 100%;
  height: 74rpx;
  margin-bottom: 16rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  border-radius: 37rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  box-shadow: 0 8rpx 14rpx rgba(95, 109, 79, 0.10);
  backdrop-filter: blur(6rpx);
}

.second-group {
  margin-top: 20rpx;
}

.group-title-text {
  font-size: 30rpx;
  color: #4f5b4d;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.option-item {
  width: 100%;
  min-height: 82rpx;
  margin-bottom: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 31rpx;
  display: flex;
  align-items: center;
  position: relative;
  box-shadow: 0 8rpx 14rpx rgba(97, 110, 80, 0.12);
  transition: all 0.2s ease;
  backdrop-filter: blur(6rpx);
}

.option-light {
  background: rgba(251, 250, 242, 0.56);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.option-blue {
  background: rgba(243, 246, 244, 0.56);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.option-green {
  background: rgba(238, 245, 234, 0.56);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.option-item.is-selected {
  border: 2rpx solid rgba(89, 128, 64, 0.42);
  box-shadow: 0 12rpx 20rpx rgba(70, 96, 53, 0.16);
  transform: translateY(-2rpx);
}

.dot {
  width: 18rpx;
  height: 18rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #cfd4c8;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
  color: #586255;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.status-dot {
  width: 18rpx;
  height: 18rpx;
  margin-left: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #c7ccc5;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.65);
}

.status-dot.is-active {
  background: #78b956;
  box-shadow: 0 0 0 4rpx rgba(120, 185, 86, 0.16);
}

.bottom-area {
  position: relative;
  margin-top: 20rpx;
  padding-top: 150rpx;
}

.wave-box {
  height: 88rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  opacity: 0.28;
}

.wave-bar {
  width: 5rpx;
  background: rgba(120, 130, 114, 0.72);
  border-radius: 4rpx 4rpx 0 0;
}

.h1 {
  height: 16rpx;
}

.h2 {
  height: 28rpx;
}

.h3 {
  height: 42rpx;
}

.h4 {
  height: 56rpx;
}

.h5 {
  height: 72rpx;
}

.generate-btn {
  width: 236rpx;
  height: 72rpx;
  position: absolute;
  margin-top: 80rpx;
  left: 50%;
  top: 14rpx;
  transform: translateX(-50%);
  border: 1rpx solid rgba(255, 255, 255, 0.38);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(247, 244, 231, 0.42);
  box-shadow:
    0 8rpx 16rpx rgba(0, 0, 0, 0.08),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(10rpx);
}

.generate-btn::after {
  border: none;
}

.generate-btn[disabled] {
  opacity: 0.72;
}

.generate-btn-text {
  font-size: 28rpx;
  color: #4f5549;
  font-weight: 700;
  text-align: center;
  letter-spacing: 3rpx;
}