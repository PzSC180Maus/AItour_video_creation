page {
height: 100vh;
min-height: 100vh;
overflow: hidden;
display: flex;
flex-direction: column;
background: linear-gradient(
180deg,
#70efd1 0%,
#ddf0ba 45%,
#ffffff 100%
);
}

page::before {
content: "";
position: fixed;
inset: 0;
background:
radial-gradient(circle at top, rgba(255, 255, 255, 0.36), transparent 40%),
linear-gradient(
180deg,
rgba(220, 242, 223, 0.22) 0%,
rgba(255, 255, 255, 0) 70%
);
pointer-events: none;
z-index: 0;
}

.container {
height: 100vh;
min-height: 100vh;
position: relative;
z-index: 1;
display: flex;
flex-direction: column;
align-items: center;
padding: 72rpx 32rpx 32rpx;
box-sizing: border-box;
overflow: hidden;
}

.upload-card {
width: 260rpx;
height: 300rpx;
margin: 16rpx auto 0;
border-radius: 38rpx;
overflow: hidden;
display: flex;
align-items: center;
justify-content: center;
background: rgba(255, 255, 255, 0.30);
border: 2rpx solid rgba(255, 255, 255, 0.42);
box-shadow:
0 14rpx 30rpx rgba(88, 103, 72, 0.16),
inset 0 0 0 2rpx rgba(255, 255, 255, 0.18);
backdrop-filter: blur(10rpx);
}

.upload-inner {
width: 100%;
height: 100%;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
background: linear-gradient(
180deg,
rgba(237, 243, 226, 0.72) 0%,
rgba(229, 236, 217, 0.54) 100%
);
}

.upload-icon {
font-size: 42rpx;
margin-bottom: 18rpx;
color: #4f6251;
font-weight: 700;
letter-spacing: 4rpx;
}

.upload-text {
font-size: 28rpx;
color: #4e5f4b;
font-weight: 700;
letter-spacing: 3rpx;
}

.avatar-image {
width: 100%;
height: 100%;
}

.group-title {
margin-top: 80rpx;
width: 100%;
height: 66rpx;
margin-bottom: 12rpx;
padding: 0 24rpx;
box-sizing: border-box;
border-radius: 33rpx;
display: flex;
align-items: center;
background:
linear-gradient(135deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.08)),
linear-gradient(
90deg,
rgba(194, 221, 255, 0.62) 0%,
rgba(180, 172, 220, 0.58) 52%,
rgba(194, 186, 157, 0.62) 100%
);
border: 1rpx solid rgba(255, 255, 255, 0.34);
box-shadow:
0 10rpx 18rpx rgba(76, 92, 130, 0.16),
inset 0 0 0 1rpx rgba(255, 255, 255, 0.12);
backdrop-filter: blur(8rpx);
}

.second-group {
margin-top: 12rpx;
}

.group-title-text {
font-size: 30rpx;
color: #2a3154;
font-weight: 700;
letter-spacing: 2rpx;
}

.option-item {
width: 100%;
min-height: 74rpx;
margin-bottom: 12rpx;
padding: 0 22rpx;
box-sizing: border-box;
border-radius: 31rpx;
display: flex;
align-items: center;
position: relative;
box-shadow: 0 8rpx 14rpx rgba(97, 110, 80, 0.12);
transition: none;
backdrop-filter: blur(6rpx);
}

.option-light {
background: rgba(251, 250, 242, 0.56);
border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.option-blue {
background: rgba(243, 246, 244, 0.56);
border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.option-green {
background: rgba(238, 245, 234, 0.56);
border: 1rpx solid rgba(255, 255, 255, 0.36);
}

.option-item.is-selected {
border: 2rpx solid rgba(89, 128, 64, 0.42);
box-shadow: 0 12rpx 20rpx rgba(70, 96, 53, 0.16);
transform: none;
}

.dot {
width: 18rpx;
height: 18rpx;
margin-right: 18rpx;
border-radius: 50%;
flex-shrink: 0;
background: #cfd4c8;
}

.option-text {
flex: 1;
font-size: 27rpx;
line-height: 1.5;
color: #586255;
font-weight: 700;
letter-spacing: 1rpx;
}

.status-dot {
width: 18rpx;
height: 18rpx;
margin-left: 16rpx;
border-radius: 50%;
flex-shrink: 0;
background: #c7ccc5;
box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.65);
}

.status-dot.is-active {
background: #78b956;
box-shadow: 0 0 0 4rpx rgba(120, 185, 86, 0.16);
}

.bottom-area {
width: 100%;
margin-top: auto;
padding-top: 8rpx;
display: flex;
flex-direction: column;
align-items: center;
gap: 12rpx;
}

.wave-box {
width: 236rpx;
height: 64rpx;
display: flex;
align-items: flex-end;
justify-content: space-between;
opacity: 0.24;
}

.wave-bar {
width: 5rpx;
background: rgba(120, 130, 114, 0.72);
border-radius: 4rpx 4rpx 0 0;
}

.h1 {
height: 16rpx;
}

.h2 {
height: 28rpx;
}

.h3 {
height: 42rpx;
}

.h4 {
height: 56rpx;
}

.h5 {
height: 72rpx;
}

.generate-btn {
width: 236rpx;
height: 72rpx;
position: relative;
margin-bottom: 50rpx;
left: auto;
top: auto;
transform: none;
border: 1rpx solid rgba(255, 255, 255, 0.38);
border-radius: 36rpx;
display: flex;
align-items: center;
justify-content: center;
background:
linear-gradient(135deg, rgba(255, 255, 255, 0.26), rgba(255, 255, 255, 0.08)),
linear-gradient(
90deg,
rgba(110, 178, 255, 0.70) 0%,
rgba(150, 132, 236, 0.64) 52%,
rgba(243, 214, 116, 0.68) 100%
);
box-shadow:
0 10rpx 18rpx rgba(84, 88, 132, 0.18),
inset 0 0 0 1rpx rgba(255, 255, 255, 0.16);
backdrop-filter: blur(10rpx);
}

.generate-btn::after {
border: none;
}

.generate-btn[disabled] {
opacity: 0.72;
}

.generate-btn-text {
font-size: 28rpx;
color: #4f5549;
font-weight: 700;
text-align: center;
letter-spacing: 3rpx;
}