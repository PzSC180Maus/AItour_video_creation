<!--pages/v_config/v_config.wxml-->
<view class="page config-page">
  <view class="safe-top"></view>

  <view class="phone-container">
    <view class="nav-bar">
      <view class="nav-btn left-btn" bindtap="goBack">
        <text class="nav-btn-text">＜</text>
      </view>

      <view class="nav-title-wrap">
        <text class="nav-title">视频生成选项</text>
      </view>

      <view class="nav-btn right-btn" bindtap="showMore">
        <text class="nav-more">•••</text>
      </view>
    </view>

    <view class="page-body">
      <view class="upload-card" bindtap="chooseAndUploadImage">
        <block wx:if="{{avatarUrl}}">
          <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
        </block>
        <block wx:else>
          <view class="upload-inner">
            <text class="upload-icon">🖼</text>
            <text class="upload-text">请上传个人肖像</text>
          </view>
        </block>
      </view>

      <view class="group-title">
        <text class="group-title-text">视频风格类别选项</text>
      </view>

      <view class="option-item option-light" bindtap="tapOption" data-name="逆光轮廓特效 电影氛围感">
        <view class="dot dot-gray"></view>
        <text class="option-text">逆光轮廓特效 电影氛围感</text>
      </view>

      <view class="option-item option-blue" bindtap="tapOption" data-name="活泼群像风格 高分辨率对比度">
        <view class="dot dot-green"></view>
        <text class="option-text">活泼群像风格 高分辨率对比度</text>
      </view>

      <view class="option-item option-green" bindtap="tapOption" data-name="无文字无字幕纯画面">
        <view class="dot dot-light"></view>
        <text class="option-text">无文字无字幕纯画面</text>
      </view>

      <view class="group-title second-group">
        <text class="group-title-text">视频优化默认选项</text>
      </view>

      <view class="option-item option-blue" bindtap="tapOption" data-name="30fps流畅播放速率输出">
        <view class="dot dot-green"></view>
        <text class="option-text">30fps流畅播放速率输出</text>
      </view>

      <view class="option-item option-blue" bindtap="tapOption" data-name="自动生成流行风格文案及BGM">
        <view class="dot dot-green"></view>
        <text class="option-text">自动生成流行风格文案及BGM</text>
      </view>

      <view class="bottom-area">
        <view class="wave-box">
          <view class="wave-bar h1"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h3"></view>
          <view class="wave-bar h4"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h1"></view>
          <view class="wave-bar h5"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h3"></view>
          <view class="wave-bar h4"></view>
          <view class="wave-bar h1"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h5"></view>
          <view class="wave-bar h3"></view>
          <view class="wave-bar h4"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h1"></view>
          <view class="wave-bar h3"></view>
          <view class="wave-bar h5"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h4"></view>
          <view class="wave-bar h3"></view>
          <view class="wave-bar h1"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h4"></view>
          <view class="wave-bar h5"></view>
          <view class="wave-bar h1"></view>
          <view class="wave-bar h2"></view>
          <view class="wave-bar h3"></view>
          <view class="wave-bar h4"></view>
        </view>

        <button class="generate-btn" bindtap="generateVideo">
          <text class="generate-btn-text">视频生成 ★</text>
        </button>
      </view>
    </view>
  </view>
</view>