page {
  min-height: 100vh;
  background: #fff9ef;
  color: #16191f;
}

.page {
  min-height: 100vh;
  padding: calc(82rpx + env(safe-area-inset-top)) 48rpx 126rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 52% 78%, rgba(234, 219, 198, 0.42) 0 16%, transparent 17%),
    linear-gradient(180deg, #fff9ef 0 34%, #e3fbff 34% 48%, #fff9ef 48% 100%);
}

.top-user-icon {
  position: absolute;
  right: 0;
  top: 12rpx;
  width: 42rpx;
  height: 42rpx;
  z-index: 2;
}

.top-user-icon::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 5rpx solid #17191f;
}

.top-user-icon::after {
  content: "";
  position: absolute;
  left: 4rpx;
  bottom: 0;
  width: 34rpx;
  height: 20rpx;
  border: 5rpx solid #17191f;
  border-bottom: 0;
  border-radius: 20rpx 20rpx 0 0;
}

.profile-head {
  position: relative;
  margin-top: 24rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-title {
  color: #30313a;
  font-size: 50rpx;
  font-weight: 900;
  font-family: Georgia, serif;
}

.edit-icon {
  position: relative;
  width: 34rpx;
  height: 34rpx;
}

.edit-icon::before {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 3rpx;
  width: 7rpx;
  height: 32rpx;
  border-radius: 6rpx;
  background: #17191f;
  transform: rotate(45deg);
}

.edit-icon::after {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: 1rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #17191f;
}

.identity-row {
  display: flex;
  align-items: center;
  gap: 62rpx;
  margin-top: 18rpx;
}

.avatar-wrap,
.avatar {
  width: 138rpx;
  height: 138rpx;
  border-radius: 50%;
}

.avatar-wrap {
  overflow: hidden;
  flex-shrink: 0;
  background: #dfe9e4;
  box-shadow: 0 0 0 5rpx rgba(255, 255, 255, 0.9);
}

.avatar {
  display: block;
  background: #dfe9e4;
}

.avatar-placeholder {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-user-symbol {
  position: relative;
  width: 56rpx;
  height: 56rpx;
}

.avatar-user-symbol::before {
  content: "";
  position: absolute;
  left: 19rpx;
  top: 0;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: rgba(22, 25, 31, 0.42);
}

.avatar-user-symbol::after {
  content: "";
  position: absolute;
  left: 9rpx;
  bottom: 3rpx;
  width: 38rpx;
  height: 25rpx;
  border-radius: 24rpx 24rpx 10rpx 10rpx;
  background: rgba(22, 25, 31, 0.42);
}

.identity {
  color: #45464f;
  font-size: 25rpx;
  line-height: 1.42;
}

.follow-row {
  margin-top: 22rpx;
}

.chip-row {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.chip {
  height: 48rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(70, 60, 82, 0.28);
  border-radius: 24rpx;
  color: #3b3c45;
  font-size: 20rpx;
  line-height: 48rpx;
  background: rgba(255, 255, 255, 0.48);
}

.tab-row {
  position: relative;
  left: -48rpx;
  width: calc(100% + 96rpx);
  height: 82rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  background: #e7fbff;
  border-bottom: 3rpx solid rgba(187, 176, 160, 0.42);
  box-sizing: border-box;
}

.primary-tabs {
  margin-top: 34rpx;
}

.secondary-tabs {
  background: rgba(255, 255, 255, 0.86);
}

.tab {
  height: 82rpx;
  color: #06080a;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 82rpx;
  text-align: center;
}

.grid-scroll {
  height: calc(100vh - 610rpx - env(safe-area-inset-top));
  margin-top: 36rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx 36rpx;
  padding: 0 18rpx 120rpx;
}

.work-card {
  overflow: hidden;
  padding: 10rpx;
  border-radius: 34rpx;
  background: rgba(214, 246, 241, 0.82);
  box-sizing: border-box;
}

.thumb {
  display: block;
  width: 100%;
  height: 144rpx;
  border-radius: 22rpx;
  background: #d8ece8;
}

.empty {
  padding: 52rpx 0;
  text-align: center;
  color: #81918a;
  font-size: 26rpx;
}

.bottom-dock {
  position: fixed;
  left: 64rpx;
  right: 64rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 20;
  height: 88rpx;
  padding: 0 52rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 8rpx 18rpx rgba(37, 65, 66, 0.16);
  box-sizing: border-box;
}

.nav-icon {
  position: relative;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #69ccc5;
  box-shadow: 0 7rpx 13rpx rgba(20, 79, 82, 0.22);
}

.nav-icon.active {
  border: 4rpx solid #ffffff;
}

.stack-symbol,
.compose-symbol,
.user-symbol {
  position: relative;
}

.stack-symbol {
  width: 42rpx;
  height: 42rpx;
}

.stack-layer {
  position: absolute;
  left: 4rpx;
  width: 34rpx;
  height: 13rpx;
}

.stack-layer-top {
  top: 5rpx;
  left: 5rpx;
  width: 34rpx;
  height: 25rpx;
  background: #102127;
  clip-path: polygon(50% 0, 100% 33%, 50% 66%, 0 33%);
}

.stack-layer-mid {
  top: 23rpx;
}

.stack-layer-bottom {
  top: 27rpx;
}

.stack-layer-mid::before,
.stack-layer-mid::after,
.stack-layer-bottom::before,
.stack-layer-bottom::after {
  content: "";
  position: absolute;
  top: 2rpx;
  width: 21rpx;
  height: 4rpx;
  border-radius: 7rpx;
  background: #102127;
}

.stack-layer-mid::before,
.stack-layer-bottom::before {
  left: 0;
  transform: rotate(25deg);
  transform-origin: right center;
}

.stack-layer-mid::after,
.stack-layer-bottom::after {
  right: 0;
  transform: rotate(-25deg);
  transform-origin: left center;
}

.compose-symbol {
  width: 36rpx;
  height: 36rpx;
}

.compose-base,
.compose-pen-cutout,
.compose-pen {
  position: absolute;
}

.compose-base {
  left: 4rpx;
  bottom: 3rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 5rpx;
  background: #102127;
}

.compose-pen-cutout {
  left: 8rpx;
  top: -14rpx;
  width: 16rpx;
  height: 37rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #69ccc5;
  transform: rotate(42deg);
  transform-origin: center bottom;
  clip-path: polygon(0 0, 100% 0, 100% 76%, 50% 100%, 0 76%);
}

.compose-pen {
  left: 15rpx;
  top: -11rpx;
  width: 10rpx;
  height: 31rpx;
  border-radius: 8rpx 8rpx 2rpx 2rpx;
  background: #102127;
  transform: rotate(42deg);
  transform-origin: center bottom;
  clip-path: polygon(0 0, 100% 0, 100% 76%, 50% 100%, 0 76%);
}

.user-symbol {
  width: 36rpx;
  height: 36rpx;
}

.user-symbol::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 3rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #102127;
}

.user-symbol::after {
  content: "";
  position: absolute;
  left: 5rpx;
  bottom: 3rpx;
  width: 26rpx;
  height: 17rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: #102127;
}
