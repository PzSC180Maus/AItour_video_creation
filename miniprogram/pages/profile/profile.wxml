<view class="page">
  <view class="profile">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view>
      <view class="name">{{userInfo.nickName || '用户'}}</view>
      <view class="sub">我的内容与收藏</view>
    </view>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'mypost' ? 'active' : ''}}" data-tab="mypost" bindtap="switchTab">我的作品</view>
    <view class="tab {{activeTab === 'mycard' ? 'active' : ''}}" data-tab="mycard" bindtap="switchTab">我的卡片</view>
    <view class="tab {{activeTab === 'post_liked' ? 'active' : ''}}" data-tab="post_liked" bindtap="switchTab">收藏作品</view>
    <view class="tab {{activeTab === 'card_liked' ? 'active' : ''}}" data-tab="card_liked" bindtap="switchTab">收藏卡片</view>
  </view>

  <scroll-view class="list" scroll-y>
    <block wx:for="{{currentList}}" wx:key="target_id">
      <view class="item" bindtap="openDetail" data-index="{{index}}">
        <image class="thumb" src="{{item.cover_url || item.image_url}}" mode="aspectFill"></image>
        <view class="body">
          <view class="title">{{item.title || item.author_name || '内容'}}</view>
          <view class="text">{{item.share_text || item.emotion_text || '暂无内容'}}</view>
        </view>
      </view>
    </block>
    <view class="empty" wx:if="{{!loading && currentList.length === 0}}">暂无内容</view>
    <view class="empty" wx:if="{{loading}}">加载中...</view>
  </scroll-view>
</view>
