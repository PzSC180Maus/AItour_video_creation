/* pages/script/script.wxss */
page {
  min-height: 100vh;
  background: #f2fff2;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.55) 0 10%, transparent 11%),
    radial-gradient(circle at 30% 86%, rgba(255, 255, 255, 0.44) 0 18%, transparent 19%),
    linear-gradient(180deg, #f3fff2 0%, #dff8ef 52%, #cceef1 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
  /* 不需要显式 height */
}
home-back-button {
  position: fixed;
  top: 50rpx;
  left: 20rpx;
  z-index: 100;
}
.page-shell {
  min-height: 80vh; /* ★ 控制卡片区域占屏幕75% */
  display: flex;
  flex-direction: column;
  padding: calc(24rpx + env(safe-area-inset-top)) 24rpx 16rpx;
  box-sizing: border-box;
}
.top-bar {
  display: flex;
  justify-content: center;
  width: 100%;
  margin-bottom: 24rpx;
}

.title-pill {
  width: 392rpx;
  max-width: 100%;
  height: 58rpx;
  line-height: 58rpx;
  margin: 0 auto;
  text-align: center;
  border-radius: 30rpx;
  background: rgba(255, 248, 241, 0.98);
  color: #2f3233;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 12rpx rgba(89, 102, 100, 0.08);
}

.script-card {
  flex: 1;
  min-height: 660rpx;
  display: flex;
  padding: 18rpx;
  border-radius: 34rpx;
  background: rgba(253, 254, 254, 0.98);
  box-shadow:
    0 10rpx 22rpx rgba(58, 90, 92, 0.10),
    inset 0 0 0 2rpx rgba(200, 216, 214, 0.88);
  box-sizing: border-box;
}

.script-text {
  flex: 1;
  width: 100%;
  height: 100%;
  min-height: 60vh;
  font-size: 28rpx;
  line-height: 1.68;
  color: #1f2c30;
  background: transparent;
  border: 0;
  box-sizing: border-box;
  padding: 18rpx 20rpx;
  display: block;
}

.script-placeholder {
  color: rgba(90, 109, 110, 0.5);
}

.action-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-btn {
  width: 420rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 8rpx 16rpx rgba(57, 83, 85, 0.10);
}

.action-btn::after {
  border: 0;
}

.action-btn[disabled] {
  opacity: 0.68;
}

.action-btn-text {
  color: #1d2124;
  font-size: 28rpx;
  font-weight: 600;
}