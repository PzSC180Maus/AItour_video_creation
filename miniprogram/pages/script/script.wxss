/* pages/script/script.wxss */
page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(
    180deg,
    #70efd1 0%,
    #ddf0ba 45%,
    #ffffff 100%
  );
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.36), transparent 40%),
    linear-gradient(
      180deg,
      rgba(220, 242, 223, 0.22) 0%,
      rgba(255, 255, 255, 0) 70%
    );
  pointer-events: none;
  z-index: 0;
}
.container {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
}
.scrollarea {
  flex: 1;
}

.page-body {
  position: relative;
  z-index: 1;
}

.script-card,
.main-btn,
.bottom-tip {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  box-shadow:
    0 16rpx 36rpx rgba(28, 56, 58, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.58);
  backdrop-filter: blur(18rpx) saturate(145%);
  -webkit-backdrop-filter: blur(18rpx) saturate(145%);
}

.script-card::before,
.main-btn::before,
.bottom-tip::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.26),
    rgba(255, 255, 255, 0.04) 55%,
    rgba(255, 255, 255, 0.14)
  );
  pointer-events: none;
}

.script-card {
  width: 90%;
  margin: 0 auto;
  border-radius: 32rpx;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
  min-height: 760rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(114, 104, 104, 0.42);
  box-shadow:
    0 16rpx 36rpx rgba(28, 52, 53, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.58);
  backdrop-filter: blur(18rpx) saturate(145%);
  -webkit-backdrop-filter: blur(18rpx) saturate(145%);
}

.script-card {
  background: rgba(255, 255, 255, 0.36);
}

.script-card::before {
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.12),
    rgba(255, 255, 255, 0.03) 55%,
    rgba(255, 255, 255, 0.08)
  );
}

.script-text {
  width: 100%;
  min-height: 680rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #0c1a1a;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.24);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  border-radius: 22rpx;
  box-sizing: border-box;
  padding: 18rpx 18rpx;
  display: block;
}

.main-btn {
  width: 320rpx;
  height: 72rpx;
  margin: 200rpx auto 0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.08)),
    linear-gradient(90deg, rgba(143, 229, 255, 0.60) 0%, rgba(171, 186, 238, 0.54) 52%, rgba(235, 226, 184, 0.58) 100%);
}

.main-btn::after {
  border: none;
}

.main-btn-text {
  position: relative;
  z-index: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #214344;
  text-align: center;
  text-shadow: 0 1rpx 6rpx rgba(255, 255, 255, 0.25);
}

.bottom-tip {
  width: 320rpx;
  height: 72rpx;
  margin: 48rpx auto 0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.08)),
    linear-gradient(90deg, rgba(143, 229, 255, 0.60) 0%, rgba(171, 186, 238, 0.54) 52%, rgba(235, 226, 184, 0.58) 100%);
}

.bottom-tip-text {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: #214344;
  font-weight: 700;
  text-align: center;
  text-shadow: 0 1rpx 6rpx rgba(255, 255, 255, 0.22);
}
