page {
  min-height: 100vh;
  background: #e7f8e6;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 150rpx 32rpx 178rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e7f8e6 0%, #d5f5f2 100%);
}

.panel,
.empty-panel {
  width: 100%;
}

.empty-panel {
  margin-top: 112rpx;
  padding: 42rpx 36rpx;
  border-radius: 34rpx;
  background: rgba(205, 242, 255, 0.92);
  box-shadow: 0 8rpx 14rpx rgba(50, 74, 71, 0.22);
  box-sizing: border-box;
}

.empty-title {
  color: #18252d;
  font-size: 36rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 18rpx;
  color: #6d7d82;
  font-size: 27rpx;
  line-height: 1.6;
}

.media-frame {
  width: 100%;
  height: 466rpx;
  padding: 10rpx;
  border-radius: 48rpx;
  background: #b6b8b8;
  box-sizing: border-box;
  overflow: hidden;
}

.video {
  width: 100%;
  height: 100%;
  border-radius: 38rpx;
  background: #d9eee7;
}

.content-box {
  width: 100%;
  min-height: 314rpx;
  margin-top: 72rpx;
  padding: 34rpx 28rpx;
  border-radius: 42rpx;
  background: #cdf3ff;
  box-shadow: 0 8rpx 12rpx rgba(58, 73, 70, 0.24);
  box-sizing: border-box;
}

.title-input {
  width: 100%;
  height: 72rpx;
  color: #18252d;
  font-size: 48rpx;
  font-weight: 400;
  line-height: 72rpx;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  margin-top: 14rpx;
  color: #18252d;
  font-size: 34rpx;
  line-height: 1.45;
}

.title-placeholder,
.text-placeholder {
  color: #9b9fa4;
}

.option-pill {
  display: flex;
  align-items: center;
  width: 100%;
  height: 100rpx;
  margin-top: 40rpx;
  padding: 0 58rpx;
  border-radius: 52rpx;
  background: #9cd9fb;
  box-shadow: 0 8rpx 10rpx rgba(58, 73, 70, 0.22);
  box-sizing: border-box;
}

.option-pill + .option-pill {
  margin-top: 32rpx;
}

.option-icon {
  flex: 0 0 auto;
  width: 52rpx;
  height: 52rpx;
  margin-right: 34rpx;
}

.location-input,
.option-text {
  flex: 1;
  height: 100rpx;
  color: #0f171d;
  font-size: 34rpx;
  line-height: 100rpx;
}

.option-placeholder {
  color: #0f171d;
}

.main-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  padding: 0;
  border: 0;
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1;
  background: #3d93c3;
  box-shadow: 0 8rpx 10rpx rgba(53, 79, 89, 0.24);
}

.publish-btn {
  width: 496rpx;
  margin: 38rpx auto 0;
}

.main-btn::after,
.sub-btn::after {
  border: 0;
}

.sub-btn {
  height: 82rpx;
  margin-top: 20rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #18252d;
  font-size: 30rpx;
}

.bottom-dock {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 30rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 128rpx;
  padding: 0 48rpx;
  border-radius: 66rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 12rpx 24rpx rgba(43, 60, 61, 0.2);
  box-sizing: border-box;
}

.nav-icon {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #69ccc5;
  box-shadow: 0 8rpx 10rpx rgba(42, 61, 61, 0.28);
}

.dock-icon-img {
  display: block;
  width: 66rpx;
  height: 66rpx;
}

.stack-img {
  width: 60rpx;
  height: 60rpx;
}

.compose-img {
  width: 60rpx;
  height: 60rpx;
  transform: translate(3rpx, -4rpx);
}

.user-img {
  width: 60rpx;
  height: 60rpx;
  transform: translate(-1rpx, -4rpx);
}
