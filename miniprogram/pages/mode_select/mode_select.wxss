/* pages/mode_select/mode_select.wxss */
page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(
    180deg,
    #70efd1 0%,
    #ddf0ba 45%,
    #ffffff 100%
  );
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.36), transparent 40%),
    linear-gradient(
      180deg,
      rgba(220, 242, 223, 0.22) 0%,
      rgba(255, 255, 255, 0) 70%
    );
  pointer-events: none;
  z-index: 0;
}

.container {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.intro-card {
  position: relative;
  z-index: 1;
  width: 420rpx;
  min-height: 620rpx;
  padding: 40rpx 28rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  display: flex;
  flex-direction: row-reverse;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 20rpx;
  background: linear-gradient(
    135deg,
    rgba(230, 249, 244, 0.72),
    rgba(205, 237, 231, 0.52)
  );
  border: 2rpx solid rgba(255, 255, 255, 0.48);
  box-shadow:
    0 18rpx 42rpx rgba(38, 84, 78, 0.14),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.intro-card::after {
  content: "";
  position: absolute;
  top: 18rpx;
  left: 22rpx;
  right: 22rpx;
  height: 34%;
  border-radius: 26rpx;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.34),
    rgba(255, 255, 255, 0.06)
  );
  pointer-events: none;
}

.page-title {
  position: relative;
  z-index: 1;
  writing-mode: vertical-rl;
  text-orientation: upright;
  font-size: 42rpx;
  font-weight: 700;
  color: #184845;
  letter-spacing: 8rpx;
  line-height: 1.2;
}

.page-desc {
  position: relative;
  z-index: 1;
  flex: 1;
  max-height: 540rpx;
  writing-mode: vertical-rl;
  text-orientation: upright;
  font-size: 28rpx;
  line-height: 1.8;
  letter-spacing: 4rpx;
  color: #2d5b57;
}

.action-group {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mode-btn {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #184845;
  letter-spacing: 2rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  box-shadow:
    0 14rpx 30rpx rgba(32, 72, 69, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(18rpx) saturate(145%);
  -webkit-backdrop-filter: blur(18rpx) saturate(145%);
}

.mode-btn::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.18) 0%,
    rgba(255, 255, 255, 0.06) 42%,
    rgba(255, 255, 255, 0.02) 100%
  );
}

.mode-btn::after {
  border: none;
}

.primary-btn {
  margin-top: 200rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0.03)),
    linear-gradient(135deg, rgba(161, 233, 214, 0.84) 0%, rgba(93, 186, 160, 0.66) 100%);
  color: #174945;
  text-shadow: 0 1rpx 6rpx rgba(255, 255, 255, 0.25);
}

.secondary-btn {
  margin-top: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0.03)),
    linear-gradient(135deg, rgba(232, 247, 241, 0.82) 0%, rgba(173, 214, 201, 0.60) 100%);
  color: #2b5e59;
}

.primary-btn:active {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
    linear-gradient(135deg, rgba(136, 220, 196, 0.88) 0%, rgba(74, 165, 141, 0.72) 100%);
}

.secondary-btn:active {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04)),
    linear-gradient(135deg, rgba(215, 238, 230, 0.84) 0%, rgba(150, 197, 183, 0.64) 100%);
}