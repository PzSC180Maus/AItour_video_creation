page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(
    180deg,
    #70efd1 0%,
    #ddf0ba 45%,
    #ffffff 100%
  );
}

page::before {
  content: "";
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.36), transparent 40%),
    linear-gradient(
      180deg,
      rgba(220, 242, 223, 0.22) 0%,
      rgba(255, 255, 255, 0) 70%
    );
  pointer-events: none;
  z-index: 0;
}

.page {
  position: relative;
  min-height: 100vh;
}

home-back-button {
  position: fixed;
  top: 50rpx;      /* 距离顶部位置 */
  left: 20rpx;      /* 距离左侧位置 */
  z-index: 100;     /* 确保在 scroll-view 上方 */
}

/* ========== 顶部图片列表（swiper） ========== */
.img-strip {
  position: fixed;
  top: 160rpx;
  left: 0;
  right: 0;
  height: 440rpx; /* 容器高度 */
  z-index: 2;
}

.img-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  box-sizing: border-box;
  padding: 20rpx 0; /* 给胶囊上下留出空间，避免放大时被裁切 */
}

/* 胶囊容器 - 非激活状态 */
.img-thumb-wrap {
  width: 560rpx;  /* 略小于 swiper-item 宽度 */
  height: 100%;
  border-radius: 48rpx; /* 胶囊圆角 */
  border: 6rpx solid rgba(255, 255, 255, 0.3); /* 半透明边框 */
  background: rgba(255, 255, 255, 0.2);
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.35s ease, border-color 0.35s ease;
  transform: scale(0.88); /* 非激活状态缩小 */
  overflow: hidden;
}

/* 激活的胶囊 - 中间项 */
.img-thumb-wrap--active {
  transform: scale(1); /* 恢复原大小 */
  border-color: #fff;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* 胶囊内的图片 */
.img-thumb {
  width: 100%;
  height: 100%;
}

/* ========== 吉祥物 + 按钮一排固定在左下 ========== */
.mascot-row {
  position: fixed;
  left: 24rpx;
  bottom: 140rpx;
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  z-index: 3;
}

.mascot-stage {
  position: relative;
  display: flex;
  align-items: center;
  pointer-events: none;
}

.mascot-stage .mascot-track {
  position: relative;
  width: 320rpx;
  min-height: 260rpx;
  overflow: visible;
}

.mascot-img {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  transition: transform 0.6s cubic-bezier(0.22, 0.9, 0.36, 1);
}

.mascot-stage .guide-bubble {
  position: absolute;
  left: 240rpx;
  top: -140rpx;
  width: 320rpx;
  padding: 20rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  box-shadow: 0 10rpx 24rpx rgba(30, 54, 53, 0.12);
  word-break: break-word;
  pointer-events: none;
  z-index: 4;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #163636;
  white-space: pre-wrap;
  word-break: break-word;
}

.camera-wrap {
  position: fixed;
  left: 400rpx;
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.camera-icon {
  width: 120rpx;
  height: 108rpx;
}

.camera-text {
  font-size: 24rpx;
  color: #214344;
  font-weight: 600;
}

.bottom-tip {
  position: fixed;
  bottom: 50rpx;
  left: 210rpx;
  width: 320rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.08)),
    linear-gradient(90deg, rgba(143, 229, 255, 0.60) 0%, rgba(171, 186, 238, 0.54) 52%, rgba(235, 226, 184, 0.58) 100%);
  z-index: 2;
}

.bottom-tip-text {
  position: relative;
  z-index: 1;
  font-size: 28rpx;
  color: #214344;
  font-weight: 700;
  text-align: center;
  text-shadow: 0 1rpx 6rpx rgba(255, 255, 255, 0.22);
}