<!--pages/dialogue/dialogue.wxml-->
<view class="page">
  <view class="ambient ambient-one"></view>
  <view class="ambient ambient-two"></view>
  <view class="ambient ambient-three"></view>
  <view class="ambient ambient-four"></view>

<view class="top-bar">
  <home-back-button></home-back-button>
  <view class="title-pill">与AI旅拍管家畅聊吧~</view>
  <view class="top-spacer"></view>
</view>

  <scroll-view class="chat-scroll" scroll-y scroll-with-animation>
    <view class="chat-list">
      <block wx:for="{{messages}}" wx:key="index">
        <view class="message-row {{item.role === 'user' ? 'user-row' : 'bot-row'}}">
          <image class="avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="bubble-wrap">
            <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'bot-bubble'}}">
              <text class="bubble-text">{{item.content}}</text>
            </view>
          </view>
        </view>
      </block>

      <view wx:if="{{showBotTyping}}" class="message-row bot-row">
        <image class="avatar {{botAnimClass}}" src="{{bot_avatar}}" mode="aspectFill"></image>
        <view class="bubble-wrap">
          <view class="bubble bot-bubble">
            <text class="bubble-text">正在输入...</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer">
    <view class="input-bar">
      <button class="tool-btn camera-btn" bindtap="finishDrawing" aria-label="跳转">
        <image class="tool-icon tool-icon-gallery" src="/images/icons/stop.png" mode="aspectFit"></image>
      </button>
      <textarea
        class="chat-input"
        value="{{inputValue}}"
        bindinput="onInputChange"
        bindconfirm="sendUserMessage"
        confirm-type="send"
        placeholder="{{initialized ? '继续补充你的想法' : '正在初始化对话...'}}"
        placeholder-class="chat-placeholder"
        auto-height
        maxlength="-1"
        cursor-spacing="24"
        disabled="{{!initialized || loading}}"
      />
      <button class="tool-btn plus-btn" bindtap="sendUserMessage" aria-label="发送">
        <image class="tool-icon tool-icon-plus" src="/images/icons/send.png" mode="aspectFit"></image>
      </button>
    </view>
  </view>
</view>

