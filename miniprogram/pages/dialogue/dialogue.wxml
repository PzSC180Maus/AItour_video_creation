<!--pages/dialogue/dialogue.wxml-->
<view class="page">
  <scroll-view class="chat-scroll" scroll-y scroll-with-animation>
    <view class="chat-list">
      <block wx:for="{{messages}}" wx:key="index">
        <view class="message-row {{item.role === 'user' ? 'user-row' : 'bot-row'}}">
          <image class="avatar" src="{{item.avatar}}"></image>
          <view class="bubble-wrap">
            <text class="speaker-name">{{item.name}}</text>
            <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'bot-bubble'}}">
              <text class="bubble-text">{{item.content}}</text>
            </view>
          </view>
        </view>
      </block>

      <view wx:if="{{showBotTyping}}" class="message-row bot-row">
        <image class="avatar {{botAnimClass}}" src="{{bot_avatar}}"></image>
        <view class="bubble-wrap">
          <text class="speaker-name">{{bot_name}}</text>
          <view class="bubble bot-bubble">
            <text class="bubble-text">正在输入...</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="footer">
    <view class="input-bar">
      <textarea
        class="chat-input"
        value="{{inputValue}}"
        bindinput="onInputChange"
        placeholder="{{initialized ? '继续补充你的想法' : '正在初始化对话...'}}"
        auto-height
        maxlength="-1"
        cursor-spacing="24"
        disabled="{{!initialized || loading}}"
      />
      <button class="send-btn" bindtap="sendUserMessage" disabled="{{!initialized || loading}}">
        发送
      </button>
    </view>

    <button class="finish-btn" bindtap="finishDrawing">
      结束会话
    </button>
  </view>
</view>